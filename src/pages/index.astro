---
import Layout from '../layouts/Layout.astro';

const tools = [
	{
		title: 'Life Insurance Needs Calculator',
		description: 'Estimate how much life insurance coverage you may need based on your income, debts, dependants, and financial goals.',
		href: `${import.meta.env.BASE_URL}tools/life-insurance-calculator/`,
		icon: '🛡️',
		tag: 'Insurance',
	},
	{
		title: 'Debt Snowball vs. Avalanche',
		description: 'Compare the two most popular debt repayment strategies. Enter your debts and an extra monthly payment to see which method saves you more money or time.',
		href: `${import.meta.env.BASE_URL}tools/debt-snowball-avalanche/`,
		icon: '❄️',
		tag: 'Debt',
	},
];
---

<Layout>
	<!-- Hero -->
	<section class="pb-12 pt-4 sm:pb-16 sm:pt-8">
		<div class="max-w-2xl">
			<p class="mb-3 inline-block rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold tracking-wide text-amber-700 uppercase">
				100% Browser-Based &middot; No Data Collected
			</p>
			<h1 class="font-display text-4xl leading-tight text-slate-900 sm:text-5xl">
				Privacy-first financial tools for Canadians
			</h1>
			<p class="mt-4 text-lg leading-relaxed text-slate-600 sm:text-xl">
				Free calculators and planning tools built for residents of Ontario, Canada. Every calculation runs entirely in your browser. Your data never leaves your device.
			</p>
		</div>
	</section>

	<!-- Tool Grid -->
	<section class="pb-16">
		<div class="mb-6 flex flex-wrap items-baseline gap-3">
			<h2 class="font-display text-2xl text-slate-900">Tools</h2>
			<span class="text-sm text-slate-400">More tools coming soon</span>
		</div>
		<div class="grid gap-5 sm:grid-cols-2">
			{tools.map((tool) => (
				<a
					href={tool.href}
					class="group relative flex flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:border-amber-300 hover:shadow-md focus:outline-none focus:ring-2 focus:ring-amber-400 focus:ring-offset-2"
				>
					<span class="mb-3 text-3xl" aria-hidden="true">{tool.icon}</span>
					<span class="mb-1 text-xs font-semibold tracking-wide text-amber-600 uppercase">{tool.tag}</span>
					<h3 class="font-display text-xl text-slate-900 group-hover:text-amber-700 transition-colors">{tool.title}</h3>
					<p class="mt-2 flex-1 text-sm leading-relaxed text-slate-500">{tool.description}</p>
					<span class="mt-4 inline-flex items-center text-sm font-medium text-amber-600 transition-colors group-hover:text-amber-700">
						Open tool
						<svg class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
					</span>
				</a>
			))}
		</div>
	</section>

	<!-- About the creator -->
	<section class="mb-6 rounded-2xl border border-slate-200 bg-white p-6 sm:p-8">
		<div class="flex items-start gap-4">
			<span class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-amber-100 font-display text-sm font-bold text-amber-700">
				JB
			</span>
			<div>
				<h3 class="font-display text-lg text-slate-900">Built by a licensed professional</h3>
				<p class="mt-1 text-sm leading-relaxed text-slate-500">
					These tools were created by <a href={`${import.meta.env.BASE_URL}about/`} class="font-medium text-amber-700 hover:underline">Jeremie Joseph Bornais</a>, a software developer and licensed life insurance agent in Ontario, Canada. The goal is to make financial estimates simple and accessible without collecting any of your data. These tools are for informational purposes only and do not constitute personalized service.
				</p>
			</div>
		</div>
	</section>

	<!-- Privacy Note -->
	<section class="rounded-2xl border border-slate-200 bg-white p-6 sm:p-8">
		<div class="flex items-start gap-4">
			<span class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-emerald-100 text-emerald-600">
				<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
			</span>
			<div>
				<h3 class="font-display text-lg text-slate-900">Your privacy is our priority</h3>
				<p class="mt-1 text-sm leading-relaxed text-slate-500">
					Every tool on this site runs entirely in your browser. We do not use cookies, analytics, or tracking scripts. No data is ever sent to a server. Your financial information stays on your device, always.
				</p>
			</div>
		</div>
	</section>
</Layout>
