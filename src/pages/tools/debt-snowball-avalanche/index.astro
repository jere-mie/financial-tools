---
import Layout from '../../../layouts/Layout.astro';
import DebtSnowballAvalanche from '../../../components/DebtSnowballAvalanche';
---

<Layout
	title="Debt Snowball vs. Avalanche Calculator | Financial Tools"
	description="Compare the Debt Snowball and Debt Avalanche repayment strategies. Enter your debts and see which method saves you more money or time. Free, private calculator for Ontario, Canada residents."
>
	<div class="mb-8">
		<a
			href={`${import.meta.env.BASE_URL}`}
			class="inline-flex items-center text-sm font-medium text-slate-500 transition-colors hover:text-amber-600"
		>
			<svg class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
				<path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
			</svg>
			Back to all tools
		</a>
	</div>

	<div class="mb-8 max-w-2xl">
		<span class="mb-3 inline-block rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold tracking-wide text-amber-700 uppercase">
			Debt
		</span>
		<h1 class="font-display text-3xl leading-tight text-slate-900 sm:text-4xl">
			Debt Snowball vs. Avalanche
		</h1>
		<p class="mt-3 text-base leading-relaxed text-slate-600 sm:text-lg">
			Enter your debts and a monthly extra payment to see how the two most popular repayment strategies compare - which saves you the most money, and which gets you debt-free fastest.
		</p>
	</div>

	<DebtSnowballAvalanche client:load />

	<!-- Disclaimer -->
	<div class="mt-12 rounded-xl border border-slate-200 bg-slate-50 p-5 sm:p-6">
		<div class="flex items-start gap-3">
			<svg class="mt-0.5 h-5 w-5 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
				<path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M12 2a10 10 0 100 20 10 10 0 000-20z" />
			</svg>
			<div class="text-xs leading-relaxed text-slate-500 sm:text-sm">
				<p class="font-semibold text-slate-600">Disclaimer</p>
				<p class="mt-1">
					This calculator is provided for <strong>educational and informational purposes only</strong> and does not constitute financial or professional advice. Results are estimates based on simplified assumptions: interest compounds monthly on the outstanding balance, and the same extra payment amount is applied every month. Actual results may vary based on your lender's compounding schedule, statement dates, and other factors not captured here.
				</p>
				<p class="mt-2">
					The "minimum payment" for credit cards in real life changes month-to-month as your balance decreases; this tool uses a fixed minimum for simplicity. Always verify repayment details with your lender. Please consult a qualified financial professional before making debt management decisions.
				</p>
				<p class="mt-2">
					<strong>Privacy:</strong> All calculations are performed entirely in your browser. No personal or financial data is collected, stored, or transmitted to any server.
				</p>
			</div>
		</div>
	</div>
</Layout>
